{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/agent-domain/v1/context-consult.schema.json",
  "title": "LLM Wiki Context Consult",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/result" }
  ],
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "revisionLock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revisionId", "revision", "fingerprint"],
      "properties": {
        "revisionId": { "type": "string", "pattern": "^memory-revision/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
        "revision": { "type": "integer", "minimum": 1 },
        "fingerprint": { "$ref": "#/$defs/digest" }
      }
    },
    "agentVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId", "profileRevision"],
      "properties": {
        "profileId": { "type": "string", "pattern": "^agent/[a-z0-9-]+$" },
        "profileRevision": { "type": "integer", "minimum": 1 }
      }
    },
    "policyDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "policyVersion", "reason", "decidedAt", "actor"],
      "properties": {
        "allowed": { "const": true },
        "policyVersion": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "decidedAt": { "$ref": "#/$defs/timestamp" },
        "actor": { "type": "string", "minLength": 1 }
      }
    },
    "provenance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "id"],
        "properties": {
          "kind": { "type": "string" },
          "id": { "type": "string" },
          "revision": { "oneOf": [{ "type": "integer" }, { "type": "string" }] },
          "fingerprint": { "$ref": "#/$defs/digest" }
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "operationTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["connector", "operation", "resource"],
      "properties": {
        "connector": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "resource": { "type": "string", "minLength": 1 }
      }
    },
    "operationWriteReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "state", "policyVersion", "approvalScope"],
      "properties": {
        "required": { "type": "boolean" },
        "state": { "enum": ["not-required", "approval-required", "approved", "denied"] },
        "policyVersion": { "type": "string", "minLength": 1 },
        "approvalScope": { "enum": ["none", "per-run"] },
        "approvedWorkRunId": { "type": "string", "pattern": "^work-run/[a-z0-9][a-z0-9-]*$" },
        "grantId": { "type": "string", "pattern": "^grant/" },
        "decisionFingerprint": { "$ref": "#/$defs/digest" }
      },
      "allOf": [{
        "if": { "properties": { "state": { "const": "approved" } } },
        "then": { "required": ["grantId", "decisionFingerprint"] }
      }]
    },
    "artifactProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "projectionId", "artifactId", "projectId", "producer", "sourceWorkRunId", "contextFingerprint", "inputArtifactIds", "contentHash", "mediaType", "outputClass", "sideEffectClass", "promotionReview", "operationWriteReview", "provenance", "warnings", "createdAt", "fingerprint"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "projectionId": { "type": "string", "pattern": "^artifact-projection/" },
        "artifactId": { "type": "string", "pattern": "^artifact/" },
        "projectId": { "type": "string", "pattern": "^project/" },
        "producer": { "type": "object" },
        "sourceWorkRunId": { "type": "string", "pattern": "^work-run/" },
        "parentWorkRunId": { "type": "string", "pattern": "^work-run/" },
        "contextFingerprint": { "$ref": "#/$defs/digest" },
        "inputArtifactIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^artifact/" } },
        "contentHash": { "$ref": "#/$defs/digest" },
        "mediaType": { "type": "string", "minLength": 1 },
        "outputClass": { "type": "string" },
        "sideEffectClass": { "type": "string" },
        "operationTarget": { "$ref": "#/$defs/operationTarget" },
        "promotionReview": { "type": "object" },
        "operationWriteReview": { "$ref": "#/$defs/operationWriteReview" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "warnings": { "type": "array", "items": { "$ref": "#/$defs/warning" } },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "fingerprint": { "$ref": "#/$defs/digest" }
      },
      "allOf": [{
        "if": { "properties": { "sideEffectClass": { "enum": ["external-write", "external-delete", "external-execute"] } } },
        "then": { "required": ["operationTarget"] }
      }]
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "requestId", "projectId", "requestingAgent", "targetAgent", "attachTo", "objective", "requestedSections", "asOf", "contextFingerprint", "capabilityGrantId", "authorizationDecision", "provenance", "createdAt", "expiresAt", "invocationTokenHash", "fingerprint"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "requestId": { "type": "string", "pattern": "^context-consult/" },
        "projectId": { "type": "string", "pattern": "^project/" },
        "requestingAgent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["profileId", "profileRevision", "workRunId"],
          "properties": {
            "profileId": { "type": "string", "pattern": "^agent/[a-z0-9-]+$" },
            "profileRevision": { "type": "integer", "minimum": 1 },
            "workRunId": { "type": "string", "pattern": "^work-run/" }
          }
        },
        "targetAgent": { "$ref": "#/$defs/agentVersion" },
        "attachTo": { "type": "object", "required": ["kind", "id"], "properties": { "kind": { "enum": ["workRun", "thread"] }, "id": { "type": "string" } } },
        "objective": { "type": "string", "minLength": 1 },
        "requestedSections": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["recentContext", "openItems", "stableMemory"] } },
        "asOf": { "$ref": "#/$defs/revisionLock" },
        "contextFingerprint": { "$ref": "#/$defs/digest" },
        "capabilityGrantId": { "type": "string", "pattern": "^grant/" },
        "authorizationDecision": { "$ref": "#/$defs/policyDecision" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "createdAt": { "$ref": "#/$defs/timestamp" },
        "expiresAt": { "$ref": "#/$defs/timestamp" },
        "invocationTokenHash": { "$ref": "#/$defs/digest" },
        "fingerprint": { "$ref": "#/$defs/digest" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "resultId", "requestId", "projectId", "requestingWorkRunId", "targetAgent", "consultedRevision", "observedCurrentRevision", "freshness", "staleForCurrentContextOperations", "provenance", "warnings", "artifact", "completedAt", "invocationTokenHash", "fingerprint"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "resultId": { "type": "string", "pattern": "^context-consult-result/" },
        "requestId": { "type": "string", "pattern": "^context-consult/" },
        "projectId": { "type": "string", "pattern": "^project/" },
        "requestingWorkRunId": { "type": "string", "pattern": "^work-run/" },
        "targetAgent": { "$ref": "#/$defs/agentVersion" },
        "consultedRevision": { "$ref": "#/$defs/revisionLock" },
        "observedCurrentRevision": { "$ref": "#/$defs/revisionLock" },
        "freshness": { "enum": ["current", "stale"] },
        "staleForCurrentContextOperations": { "type": "boolean" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "warnings": { "type": "array", "items": { "$ref": "#/$defs/warning" } },
        "artifact": { "$ref": "#/$defs/artifactProjection" },
        "completedAt": { "$ref": "#/$defs/timestamp" },
        "invocationTokenHash": { "$ref": "#/$defs/digest" },
        "fingerprint": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
