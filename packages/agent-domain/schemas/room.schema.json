{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/agent-domain/v1/room.schema.json",
  "title": "Governed Agent Room v1",
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "projectId", "profileId", "profileRevision", "bindingId", "bindingRevision", "threadId", "threadRevision"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "projectId": { "$ref": "common.schema.json#/$defs/projectId" },
        "profileId": { "$ref": "common.schema.json#/$defs/agentProfileId" },
        "profileRevision": { "type": "integer", "minimum": 1 },
        "bindingId": { "$ref": "common.schema.json#/$defs/bindingId" },
        "bindingRevision": { "type": "integer", "minimum": 1 },
        "threadId": { "$ref": "common.schema.json#/$defs/threadId" },
        "threadRevision": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/identity" },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "identity", "readOnly", "lifecycle", "relatedWorkRunIds", "approvedMemory", "connectorSummaries", "diagnostics"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "identity": { "$ref": "#/$defs/identity" },
        "readOnly": { "const": true },
        "lifecycle": { "enum": ["open", "closed", "archived"] },
        "relatedWorkRunIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^work-run/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" } },
        "approvedMemory": {
          "oneOf": [
            { "type": "null" },
            { "type": "object", "additionalProperties": false, "required": ["revisionId", "revision", "fingerprint"], "properties": { "revisionId": { "type": "string", "pattern": "^memory-revision/" }, "revision": { "type": "integer", "minimum": 1 }, "fingerprint": { "$ref": "common.schema.json#/$defs/digest" } } }
          ]
        },
        "connectorSummaries": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["connectorId", "status"], "properties": { "connectorId": { "type": "string", "minLength": 1 }, "status": { "enum": ["available", "degraded", "unavailable", "disabled"] }, "grantRef": { "type": "string", "pattern": "^grant/" }, "remediationKey": { "type": "string", "minLength": 1 } } } },
        "diagnostics": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["code", "severity"], "properties": { "code": { "type": "string", "minLength": 1 }, "severity": { "enum": ["info", "warning", "error"] }, "remediationKey": { "type": "string", "minLength": 1 } } } }
      }
    }
  ]
}
