{
  "name": "@obsidian-llm-wiki/agent-domain",
  "version": "0.1.0",
  "description": "Host-neutral governed Agent Room, Context Envelope, and Dream Time domain core for LLM Wiki.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "schemas",
    "fixtures",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests/"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "~6.0.3"
  },
  "license": "GPL-3.0-only"
}
