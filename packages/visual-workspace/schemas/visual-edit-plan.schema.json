{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/visual-workspace/v1/visual-edit-plan.schema.json",
  "title": "VisualEditPlan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "preview", "affectedPaths", "provenance", "warnings", "fingerprint"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/vaultPath" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "preview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": { "$ref": "#/$defs/snapshot" },
        "after": { "$ref": "#/$defs/snapshot" }
      }
    },
    "affectedPaths": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/vaultPath" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "origin"],
      "properties": {
        "actor": { "$ref": "#/$defs/singleLine" },
        "origin": { "enum": ["user", "assistant", "import"] }
      }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/singleLine" }
    },
    "fingerprint": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "pattern": "^[^\\r\\n]+$"
    },
    "vaultPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.\\.?(?:/|$))[^\\r\\n]+$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "blockId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,127}$"
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "$ref": "#/$defs/blockId" },
        "label": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/blockId" },
        "to": { "$ref": "#/$defs/blockId" }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "id", "title", "rootId", "nodes", "edges"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "id": { "$ref": "#/$defs/blockId" },
        "title": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" },
        "rootId": { "$ref": "#/$defs/blockId" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "documentFingerprint", "managedMarkdown"],
      "properties": {
        "document": { "$ref": "#/$defs/document" },
        "documentFingerprint": { "$ref": "#/$defs/sha256" },
        "managedMarkdown": { "type": "string", "minLength": 1 }
      }
    }
  }
}
