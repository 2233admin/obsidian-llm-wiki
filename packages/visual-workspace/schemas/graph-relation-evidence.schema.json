{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/visual-workspace/v1/graph-relation-evidence.schema.json",
  "title": "GraphRelationEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "adapter",
    "relation",
    "fromNodeId",
    "toNodeId",
    "confidence",
    "evidence"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/stableIdentity" },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "#/$defs/stableIdentity" },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[^\\r\\n]+$"
        }
      }
    },
    "relation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\r\\n]+$"
    },
    "fromNodeId": { "$ref": "#/$defs/blockId" },
    "toNodeId": { "$ref": "#/$defs/blockId" },
    "confidence": { "enum": ["extracted", "inferred", "ambiguous", "unknown"] },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value"],
        "properties": {
          "kind": { "enum": ["vault", "url", "adapter"] },
          "value": { "$ref": "#/$defs/singleLine" }
        }
      }
    }
  },
  "$defs": {
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000,
      "pattern": "^[^\\r\\n]+$"
    },
    "blockId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,127}$"
    },
    "stableIdentity": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,255}$"
    }
  }
}
