{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/visual-workspace/v1/mind-map-document.schema.json",
  "title": "MindMapDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "title", "rootId", "nodes", "edges"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/blockId" },
    "title": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" },
    "rootId": { "$ref": "#/$defs/blockId" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "blockId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,127}$"
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "$ref": "#/$defs/blockId" },
        "label": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/blockId" },
        "to": { "$ref": "#/$defs/blockId" }
      }
    }
  }
}
