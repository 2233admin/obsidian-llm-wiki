{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/visual-workspace/v1/mind-map-document.schema.json",
  "title": "MindMapDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "title", "rootId", "nodes", "edges"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "$ref": "#/$defs/blockId" },
    "title": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" },
    "rootId": { "$ref": "#/$defs/blockId" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "crossLinks": {
      "type": "array",
      "items": { "$ref": "#/$defs/crossLink" }
    }
  },
  "$defs": {
    "blockId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-]{0,127}$"
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "$ref": "#/$defs/blockId" },
        "label": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": { "$ref": "#/$defs/blockId" },
        "to": { "$ref": "#/$defs/blockId" }
      }
    },
    "crossLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "from", "to", "relation", "provenance"],
      "properties": {
        "id": { "$ref": "#/$defs/blockId" },
        "from": { "$ref": "#/$defs/blockId" },
        "to": { "$ref": "#/$defs/blockId" },
        "relation": { "type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$" },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "enum": ["explicit", "graph_relation_evidence", "model_suggestion"] },
            "evidenceId": { "$ref": "#/$defs/stableIdentity" },
            "adapterId": { "$ref": "#/$defs/stableIdentity" },
            "confidence": { "enum": ["extracted", "inferred", "ambiguous", "unknown"] }
          }
        }
      }
    },
    "stableIdentity": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,255}$"
    }
  }
}
