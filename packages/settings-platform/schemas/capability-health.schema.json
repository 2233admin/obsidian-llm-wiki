{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.llmwiki.org/settings/v1/capability-health.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["capabilityId", "state", "summary", "evidence", "remediations", "checkedAt", "snapshotId"],
  "properties": {
    "capabilityId": { "type": "string", "minLength": 1 },
    "state": { "enum": ["available", "degraded", "unavailable", "disabled"] },
    "summary": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "summary", "status", "observedAt"],
        "properties": {
          "code": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "enum": ["pass", "warn", "fail"] },
          "observedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "remediations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "summary"],
        "properties": {
          "code": { "type": "string" },
          "summary": { "type": "string" },
          "operation": { "type": "string" }
        }
      }
    },
    "checkedAt": { "type": "string", "format": "date-time" },
    "snapshotId": { "type": "string", "minLength": 1 }
  }
}
