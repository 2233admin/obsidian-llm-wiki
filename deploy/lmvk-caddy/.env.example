# LMVK L3 caddy — 环境配置。复制为 .env 后填写: cp .env.example .env
# .env 不入库 (含拓扑细节); 本 example 只有占位符。

# NetBird 舰队网接口地址 —— 宿主机上 `netbird status` 或 `ip addr show`
# (接口名通常是 wt0 / nb-*) 查看。必须落在 100.64.0.0/10 段。
# !!! 严禁 0.0.0.0 —— spec L3 红线 !!!
NETBIRD_ADDR=100.x.y.z

# 分发端口。默认 8443, 避开 gitea 的 8418; 若宿主机被占用可换。
LMVK_PORT=8443

# pages 分支 checkout 的宿主机绝对路径 (= sync-pages.sh 的 LMVK_PAGES_DIR)。
PAGES_DIR=/srv/lmvk/pages
