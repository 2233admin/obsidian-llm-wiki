{
  "name": "obsidian-llm-wiki",
  "version": "0.4.0-beta.1",
  "description": "Obsidian control surface for LLM Wiki settings, health, and governed knowledge operations.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "platforms:build": "node build-shared-domains.mjs",
    "prebuild": "npm run platforms:build",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "pretest": "npm run platforms:build",
    "test": "node test-settings.mjs",
    "pretypecheck": "npm run platforms:build",
    "typecheck": "tsc --noEmit",
    "verify:bundle-boundary": "node verify-production-bundle.mjs"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^20.14.0",
    "esbuild": "0.21.5",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.5"
  }
}
