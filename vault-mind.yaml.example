# vault-mind configuration
# Copy to vault-mind.yaml and edit

vault_path: "/path/to/your/vault"

# Adapters -- enable what you have, disable what you don't
adapters:
  filesystem:
    enabled: true  # default, always works
  obsidian:
    enabled: false
    ws_url: "ws://127.0.0.1:27124"
    token: "${VAULT_MIND_OBSIDIAN_TOKEN}"
  memu:
    enabled: false
    pg_url: "postgresql://user:pass@localhost:5432/memu"
  gitnexus:
    enabled: false

# --- VaultBrain adapter (semantic search via PGLite + pgvector) ---
# Enables hybrid search (keyword + vector) across all indexed vault files.
# Files are indexed automatically on create/modify. Run vault.reindex to bulk-index existing files.
#
# Engine options: pglite (embedded, no server needed) | postgres (external Postgres + pgvector)
# vaultbrain_engine: pglite
#
# Data directory for PGLite storage (default: ~/.vault-mind/vaultbrain)
# vaultbrain_data_dir: ~/.vault-mind/vaultbrain
#
# OpenAI API key for vector embeddings (text-embedding-3-small).
# If omitted, adapter falls back to keyword-only search (pg_trgm).
# Can also be set via OPENAI_API_KEY environment variable.
# openai_api_key: sk-...
#
# Weight of VaultBrain results in unified search fusion (default: 1.0)
# Higher than filesystem (0.3) because semantic results are more precise.
# adapter_weight_vaultbrain: 1.2

# Compiler settings
compiler:
  model_tier: "haiku"  # haiku (cheap) | sonnet (balanced) | opus (precise)
  chunk_size: 1000
  chunk_overlap: 200
  auto_compile_threshold: 3  # dirty files before auto-compile triggers

# Agent scheduler
agent:
  enabled: true
  night_mode_start: "22:00"
  night_mode_end: "08:00"
  days_since_emerge_threshold: 14
  orphan_threshold: 10

# Unified query weights (higher = more relevant in merged results)
query:
  weights:
    vault: 1.0
    memu: 0.8
    gitnexus: 0.6

# Collaborative vault governance (used by scripts/init_collab_vault.py and
# scripts/vault_collab_lint.py; MCP write enforcement can consume the same
# policy in a later release). The init script also writes a conservative vault
# .gitignore for Obsidian workspace state, sync conflict copies, and local
# LLMwiki runtime files.
collaboration:
  actor: "codex"
  role: "agent"
  enforce: true
  allowed_write_paths:
    - "00-Inbox/AI-Output/codex/**"
    - "10-Projects/*/agents/codex/**"
  protected_paths:
    - "20-Decisions/**"
    - "30-Architecture/**"
    - "40-Runbooks/**"
    - "README.md"
