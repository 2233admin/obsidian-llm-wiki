#!/usr/bin/env bash
# LLMwiki setup -- legacy-compatible host skill install.
#
# Claude Code users should prefer the plugin path in README:
# /plugin marketplace add 2233admin/obsidian-llm-wiki
# /plugin install llmwiki@obsidian-llm-wiki
#
# This script remains the portable path for Codex, OpenCode, Gemini,
# and existing users who installed the legacy vault-wiki skill bundle.

set -euo pipefail

HOST="claude"
DRY_RUN=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    --host)
      [ "$#" -lt 2 ] && echo "Error: --host requires a value" >&2 && exit 1
      HOST="$2"
      shift 2
      ;;
    --host=*)
      HOST="${1#--host=}"
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      echo "Usage: bash ./setup [--host claude|codex|opencode|gemini] [--dry-run]"
      exit 0
      ;;
    *)
      echo "Error: unknown argument '$1'" >&2
      exit 1
      ;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
case "$(uname -s)" in
  MINGW*|MSYS*|CYGWIN*) SCRIPT_DIR="$(cygpath -m "$SCRIPT_DIR")" ;;
esac

MANIFEST_PATH="$SCRIPT_DIR/packaging/llmwiki-distribution.json"
[ -f "$MANIFEST_PATH" ] || { echo "Error: missing distribution manifest: $MANIFEST_PATH" >&2; exit 1; }

manifest_eval() {
  local expr="$1"
  node -e "const m=require(process.argv[1]); const v=($expr); if (Array.isArray(v)) console.log(v.join('\n')); else console.log(v);" "$MANIFEST_PATH"
}

PUBLIC_NAME="$(manifest_eval "m.publicName")"
DISPLAY_NAME="$(manifest_eval "m.displayName")"
LEGACY_SKILL_BUNDLE="$(manifest_eval "m.legacySkillBundle")"
MCP_SERVER_NAME="$(manifest_eval "m.mcpServerName")"
VAULT_PATH_ENV="$(manifest_eval "m.vaultPathEnv")"
PLUGIN_MARKETPLACE="$(manifest_eval "m.pluginInstall.marketplace")"
PLUGIN_INSTALL="$(manifest_eval "m.pluginInstall.install")"

if ! manifest_eval "Object.keys(m.hosts)" | grep -qx "$HOST"; then
  echo "Error: unknown host '$HOST'. Expected: $(manifest_eval "Object.keys(m.hosts)" | paste -sd ', ' -)" >&2
  exit 1
fi

SKILLS_TEMPLATE="$(manifest_eval "m.hosts['$HOST'].skillsDir")"
SKILLS_DIR="${SKILLS_TEMPLATE//\{home\}/$HOME}"
SKILLS_DIR="${SKILLS_DIR//\{legacySkillBundle\}/$LEGACY_SKILL_BUNDLE}"
PARENT_DIR="$(dirname "$SKILLS_DIR")"

BUNDLE_PATH="$SCRIPT_DIR/mcp-server/bundle.js"
if [ ! -f "$BUNDLE_PATH" ]; then
  cat >&2 <<EOF
Error: mcp-server/bundle.js not found at $BUNDLE_PATH

Build it first:
  cd mcp-server && npm install && npm run rebuild

Released tarballs ship bundle.js pre-built; this usually only happens when
installing from an actively changing source checkout.
EOF
  exit 1
fi

run() {
  if [ "$DRY_RUN" -eq 1 ]; then
    printf '[dry-run]'
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  else
    "$@"
  fi
}

copy_path() {
  local src="$1"
  local dest="$2"
  [ -e "$src" ] || return 0
  run cp -R "$src" "$dest"
}

if [ ! -d "$PARENT_DIR" ] && [ "$DRY_RUN" -eq 0 ]; then
  echo "Error: host skills directory not found: $PARENT_DIR" >&2
  echo "Install or launch $HOST once, then re-run setup." >&2
  exit 1
fi

run mkdir -p "$SKILLS_DIR"

while IFS= read -r dir; do
  copy_path "$SCRIPT_DIR/$dir" "$SKILLS_DIR/"
done < <(manifest_eval "m.install.copyDirs")

while IFS= read -r file; do
  copy_path "$SCRIPT_DIR/$file" "$SKILLS_DIR/"
done < <(manifest_eval "m.install.copyFiles")

run mkdir -p "$SKILLS_DIR/mcp-server"
while IFS= read -r file; do
  copy_path "$SCRIPT_DIR/$file" "$SKILLS_DIR/mcp-server/"
done < <(manifest_eval "m.install.mcpFiles")

INSTALLED_SKILLS=0
while IFS= read -r skill; do
  skill_dir="$SCRIPT_DIR/skills/$skill"
  [ -f "$skill_dir/SKILL.md" ] || continue
  run mkdir -p "$PARENT_DIR/$skill"
  run cp -R "$skill_dir/." "$PARENT_DIR/$skill/"
  INSTALLED_SKILLS=$((INSTALLED_SKILLS + 1))
done < <(manifest_eval "m.install.topLevelSkills")

INSTALL_PATH="$SKILLS_DIR/mcp-server/bundle.js"

cat <<EOF

$DISPLAY_NAME installed to legacy-compatible skill bundle:
  $SKILLS_DIR
Top-level skills registered: $INSTALLED_SKILLS

Next steps for $HOST:
1. Add this MCP entry to your host config:

{"mcpServers":{"$MCP_SERVER_NAME":{"command":"node","args":["$INSTALL_PATH"],"env":{"$VAULT_PATH_ENV":"YOUR_VAULT_PATH"}}}}

2. Restart $HOST and ask a cited vault question, for example:
   What do I know about attention heads? Use vault/search tools and cite notes.

Claude Code users can skip this script and use the plugin path instead:
  $PLUGIN_MARKETPLACE
  $PLUGIN_INSTALL

Manifest source: packaging/llmwiki-distribution.json ($PUBLIC_NAME)
EOF
