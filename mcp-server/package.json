{
  "name": "@obsidian-llm-wiki/mcp",
  "version": "0.2.0",
  "description": "A faithful reference implementation of Karpathy's LLM Wiki pattern -- headless-first MCP server, plain markdown, keyword recall out of the box (semantic recall is an optional Ollama upgrade), Obsidian-native.",
  "type": "module",
  "main": "bundle.js",
  "types": "dist/index.d.ts",
  "bin": {
    "obsidian-llm-wiki-mcp": "bundle.js",
    "memu-query": "dist/scripts/memu-query.js"
  },
  "files": [
    "bundle.js",
    "dist/scripts/memu-query.js",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bundle.js",
    "start:dev": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/ src/",
    "test:legacy": "bun test tests/",
    "test:source": "bun test src/",
    "memu-query": "node dist/scripts/memu-query.js",
    "sync-vault-to-memu": "node dist/scripts/sync-vault-to-memu.js",
    "claude-mem-sync": "node dist/scripts/claude-mem-sync.js",
    "generate-tools-doc": "node dist/scripts/generate-tools-doc.js",
    "bundle": "esbuild dist/index.js --bundle --platform=node --target=node20 --format=esm --outfile=bundle.js --external:@electric-sql/pglite --external:@electric-sql/pglite/* --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" --log-level=warning",
    "rebuild": "npm run build && npm run bundle",
    "verify:bundle": "npm run rebuild && git diff --exit-code -- bundle.js"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-3.0-only"
}
